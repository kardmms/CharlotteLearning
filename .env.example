# Copy this file to .env before running locally.
# Generate with: openssl rand -base64 32
AUTH_SECRET="replace-with-at-least-32-random-characters"

# Managed Postgres connection string (Prisma Postgres, Neon, Supabase, etc.).
DATABASE_URL="postgresql://user:password@host:5432/charlotte?sslmode=require"

# Server-only. Never paste this into browser code.
OPENAI_API_KEY=""
# Existing Vercel projects may use this alternate spelling; either one works.
OPEN_AI_KEY=""

# Optional. Override if you want to use a different OpenAI model.
OPENAI_MODEL="gpt-4o-mini"

# Optional bot protection for public forms. Create these in Cloudflare Turnstile.
# Set TURNSTILE_REQUIRED="true" in production after both keys are deployed.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=""
TURNSTILE_SECRET_KEY=""
TURNSTILE_REQUIRED="false"

# Required for Vercel Cron to run protected maintenance jobs.
# Generate with: openssl rand -base64 32
CRON_SECRET=""

# Privacy and outbound defaults. Keep outbound hosts comma-separated and hostname-only.
CONTACT_LEAD_RETENTION_DAYS="180"
ALLOWED_OUTBOUND_HOSTS="api.openai.com,challenges.cloudflare.com"
